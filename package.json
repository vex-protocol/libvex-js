{
    "name": "@vex-chat/libvex",
    "version": "1.0.3",
    "description": "Library for communicating with xchat server.",
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./preset/tauri": {
            "types": "./dist/preset/tauri.d.ts",
            "import": "./dist/preset/tauri.js"
        }
    },
    "files": [
        "dist"
    ],
    "author": "Extra <extrahash@protonmail.com>",
    "license": "AGPL-3.0-or-later",
    "engines": {
        "node": ">=24.0.0"
    },
    "scripts": {
        "build": "rimraf dist && tsc",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "prepare": "husky",
        "prepack": "npm run build",
        "docs": "npx typedoc --options typedoc.json",
        "test": "vitest run",
        "test:node": "vitest run -c vitest.config.node.ts",
        "test:browser": "vitest run -c vitest.config.browser.ts",
        "test:rn": "vitest run -c vitest.config.rn.ts",
        "test:platforms": "vitest run -c vitest.config.node.ts && vitest run -c vitest.config.browser.ts && vitest run -c vitest.config.rn.ts"
    },
    "devDependencies": {
        "@tauri-apps/plugin-sql": "^2.4.0",
        "@types/browser-or-node": "^1.3.0",
        "@types/btoa": "^1.2.3",
        "@types/ed2curve": "^0.2.4",
        "@types/node": "^24.12.2",
        "@types/object-hash": "^1.3.4",
        "@types/uuid": "^8.3.0",
        "@types/ws": "^8.5.10",
        "@typescript-eslint/eslint-plugin": "^8.57.1",
        "@typescript-eslint/parser": "^8.57.1",
        "dotenv": "^8.2.0",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^9.0.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.3.2",
        "prettier": "^3.2.0",
        "rimraf": "^6.1.3",
        "typedoc": "^0.28.0",
        "typescript": "^6.0.2",
        "vitest": "^3.0.0"
    },
    "overrides": {
        "@types/ws": "^8.5.10"
    },
    "dependencies": {
        "@extrahash/sleep": "^1.0.0",
        "@vex-chat/crypto": "^1.1.1",
        "@vex-chat/types": "^1.0.1",
        "axios": "^1.7.0",
        "better-sqlite3": "^11.0.0",
        "browser-or-node": "^1.3.0",
        "btoa": "^1.2.1",
        "knex": "^3.1.0",
        "msgpackr": "1.11.8",
        "object-hash": "^2.1.1",
        "parse-duration": "^2.0.0",
        "picocolors": "^1.1.1",
        "tweetnacl": "^1.0.3",
        "uuid": "^8.3.1",
        "winston": "^3.3.3",
        "ws": "^8.17.0"
    },
    "peerDependencies": {
        "@tauri-apps/plugin-sql": ">=2.0.0"
    },
    "peerDependenciesMeta": {
        "@tauri-apps/plugin-sql": {
            "optional": true
        }
    },
    "directories": {
        "doc": "docs"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/vex-chat/vex-js.git"
    },
    "bugs": {
        "url": "https://github.com/vex-chat/vex-js/issues"
    },
    "homepage": "https://github.com/vex-chat/vex-js#readme",
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "lint-staged": {
        "*.ts": [
            "eslint --fix",
            "prettier --write"
        ]
    }
}
